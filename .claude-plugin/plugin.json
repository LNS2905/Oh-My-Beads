{
  "name": "oh-my-beads",
  "version": "1.3.0",
  "description": "Multi-agent orchestration plugin for Claude Code. Combines role-based specialization (Scout, Architect, Worker, Reviewer) under a Master Orchestrator, using beads_village for task tracking and concurrency safety.",
  "author": {
    "name": "sangnhat",
    "email": "sangnhat@example.com"
  },
  "repository": "https://github.com/LNS2905/oh-my-beads",
  "homepage": "https://github.com/LNS2905/oh-my-beads",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "multi-agent",
    "orchestration",
    "beads-village",
    "task-management"
  ],
  "agents": [
    "./agents/master.md",
    "./agents/scout.md",
    "./agents/fast-scout.md",
    "./agents/architect.md",
    "./agents/worker.md",
    "./agents/reviewer.md",
    "./agents/explorer.md",
    "./agents/executor.md",
    "./agents/verifier.md",
    "./agents/code-reviewer.md",
    "./agents/security-reviewer.md",
    "./agents/test-engineer.md"
  ],
  "skills": "./skills/",
  "setup": "./skills/setup/SKILL.md",
  "mcpServers": "./.mcp.json",
  "prerequisites": {
    "node": ">=18.0.0",
    "beads-village": {
      "description": "MCP server for task tracking and file locking",
      "install": "See https://github.com/LNS2905/oh-my-beads#prerequisites"
    }
  }
}
